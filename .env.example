PRODUCTS_NGINX_PORT=8080
PRODUCT_SERVICE_1_HOST=product_service_1
PRODUCT_SERVICE_2_HOST=product_service_2
PRODUCT_SERVICE_PORT=8002

# Address of the users nginx server, not the raw FastAPI container.
USERS_SERVICE_URL=http://users-server:8001

# Neon/PostgreSQL connection string shared by product_service_1 and product_service_2.
PRODUCT_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require&channel_binding=require
